# Canvas LMS
CANVAS_API_TOKEN=your_canvas_api_token_here
CANVAS_BASE_URL=https://canvas.uw.edu
DEFAULT_COURSE_ID=your_course_id_here

# Anthropic Claude (for AI grading)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Login credentials — three options (first one found wins):
# Option A (local): create data/users.json  → [{"username":"...","password":"...","role":"admin"}]
# Option B (cloud): set USERS_JSON env var as a JSON array string (no file needed)
# USERS_JSON=[{"username":"marco","password":"...","role":"admin"},{"username":"marlowe","password":"...","role":"admin"}]
# Option C (single user fallback):
TA_USERNAME=admin
TA_PASSWORD=changeme
SESSION_SECRET=replace-with-a-long-random-string

# Server
PORT=3000
